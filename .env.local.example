# Kopieer dit bestand naar .env.local en vul je Supabase-gegevens in.
# Te vinden in Supabase: Project Settings > API.

NEXT_PUBLIC_SUPABASE_URL=https://JOUW-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=jouw-anon-public-key

# Alleen server-side gebruikt voor het aanmaken van inlogaccounts.
# Te vinden in Supabase: Project Settings > API > service_role (secret).
# DEEL DEZE NOOIT en zet hem niet in een NEXT_PUBLIC_ variabele.
SUPABASE_SERVICE_ROLE_KEY=jouw-service-role-secret-key

# Gedeeld geheim waarmee de e-learning resultaten mag insturen (koppelpunt /api/elearning/result).
# Verzin een lange willekeurige string en zet dezelfde waarde in de e-learning.
ELEARNING_API_KEY=verzin-een-lange-willekeurige-sleutel

# Resend — voor het versturen van uitnodigings-/auth-mails (Gebruikers & toegang).
# API-key uit resend.com > API Keys. Zonder deze key valt het systeem terug op Supabase-mail.
RESEND_API_KEY=re_jouw_resend_api_key
# Afzender; het domein moet in Resend geverifieerd zijn (SPF/DKIM).
RESEND_FROM=Plaza Boat College <noreply@plazaboatcollege.com>
